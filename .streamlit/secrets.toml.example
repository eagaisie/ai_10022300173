# Copy to `secrets.toml` in this folder (gitignored). Streamlit Cloud: same keys in Secrets.

# --- OpenAI ---
# LLM_API_KEY = "sk-..."
# LLM_MODEL = "gpt-4o-mini"
# LLM_API_URL = "https://api.openai.com/v1/chat/completions"

# --- Groq (OpenAI-compatible; auto URL if key starts with gsk_ or use LLM_PROVIDER) ---
# GROQ_API_KEY = "gsk_..."
# LLM_MODEL = "llama-3.3-70b-versatile"
# LLM_PROVIDER = "groq"
# LLM_API_URL = "https://api.groq.com/openai/v1/chat/completions"

# OPENAI_API_KEY = "sk-..."   # mapped to LLM_API_KEY when LLM_API_KEY unset
# HF_TOKEN = "hf_..."
