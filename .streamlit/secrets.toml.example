# Copy this file to `secrets.toml` in the same folder (`.streamlit/secrets.toml`).
# `secrets.toml` is gitignored. Then run: streamlit run app.py
#
# Streamlit Community Cloud: Manage app → Settings → Secrets (same keys).

# LLM_API_KEY = "sk-..."
# LLM_MODEL = "gpt-4o-mini"
# optional:
# LLM_API_URL = "https://api.openai.com/v1/chat/completions"
# OPENAI_API_KEY = "sk-..."   # mapped to LLM_API_KEY by app.py if LLM_API_KEY is unset
# HF_TOKEN = "hf_..."
