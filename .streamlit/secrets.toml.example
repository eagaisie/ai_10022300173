# Copy this file to `secrets.toml` in the same folder (`.streamlit/secrets.toml`).
# `secrets.toml` is gitignored. Then run: streamlit run app.py
#
# Streamlit Community Cloud: Manage app → Settings → Secrets (same keys).

# --- Pick ONE provider block (uncomment and fill). ---

# OpenAI (default chat URL is api.openai.com):
# LLM_API_KEY = "sk-..."
# LLM_MODEL = "gpt-4o-mini"

# Groq (OpenAI-compatible; URL auto-selected if key starts with gsk_ or LLM_PROVIDER=groq):
# GROQ_API_KEY = "gsk_..."
# LLM_MODEL = "llama-3.3-70b-versatile"
# LLM_PROVIDER = "groq"
# LLM_API_URL = "https://api.groq.com/openai/v1/chat/completions"

# Optional:
# HF_TOKEN = "hf_..."
