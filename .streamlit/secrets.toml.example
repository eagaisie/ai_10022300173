# Copy to `secrets.toml` in this folder (gitignored). Streamlit Cloud: same keys in Secrets.
# LLM calls use Groq only (OpenAI-compatible JSON).

GROQ_API_KEY = "gsk_..."
LLM_MODEL = "llama-3.3-70b-versatile"

# Or put the key in LLM_API_KEY instead of GROQ_API_KEY:
# LLM_API_KEY = "gsk_..."

# optional:
# LLM_API_URL = "https://api.groq.com/openai/v1/chat/completions"
# HF_TOKEN = "hf_..."
