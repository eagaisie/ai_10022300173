# Copy this file to `secrets.toml` in the same folder (`.streamlit/secrets.toml`).
# `secrets.toml` is gitignored. Then run: streamlit run app.py
#
# Streamlit Community Cloud: use Manage app → Settings → Secrets (same keys).

LLM_API_KEY = "sk-replace-with-your-key"
LLM_MODEL = "gpt-4o-mini"

# Optional aliases (app maps OPENAI_API_KEY → LLM_API_KEY if LLM_API_KEY is unset):
# OPENAI_API_KEY = "sk-..."
# HF_TOKEN = "hf_..."
